{
  "name": "@codemonster-ru/vueforge-theme",
  "version": "1.2.2",
  "description": "Shared theme engine, tokens, and preset runtime for the VueForge ecosystem.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codemonster-ru/vueforge-theme#readme",
  "bugs": {
    "url": "https://github.com/codemonster-ru/vueforge-theme/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codemonster-ru/vueforge-theme.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "vueforge",
    "theme",
    "tokens",
    "design-system",
    "runtime"
  ],
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/jsdom": "^21.1.7",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  }
}
